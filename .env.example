# GitHub Hot Hub 配置
# 复制此文件为 .env 并填入你的配置

# GitHub Personal Access Token（强烈建议配置，否则 API 限制为 60次/小时）
# 获取: https://github.com/settings/tokens → Generate new token (classic) → 勾选 public_repo
GHH_GITHUB_TOKEN=

# 企业微信 Webhook 地址（后续推送功能使用）
GHH_WECOM_WEBHOOK_URL=

# 评分权重 (可选调整，默认值已经过调优)
# GHH_SCORE_WEIGHT_STAR_SPEED=0.40
# GHH_SCORE_WEIGHT_ACCELERATION=0.20
# GHH_SCORE_WEIGHT_RELATIVE_GROWTH=0.20
# GHH_SCORE_WEIGHT_FRESHNESS=0.10
# GHH_SCORE_WEIGHT_COMMUNITY=0.10

# 最低日增 star 门槛
# GHH_MIN_STARS_TODAY=50

# 报告展示的项目数量
# GHH_REPORT_TOP_N=15
